{
  "name": "mux",
  "version": "0.1.0",
  "description": "Minimal hybrid team orchestration extracted from OMC",
  "type": "module",
  "bin": {
    "mux": "bin/mux.cjs"
  },
  "files": [
    "bin",
    "dist",
    "runtime/mux_runtime/**/*.py",
    "plugin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:node": "vitest run tests/node",
    "test:runtime": "python3 tests/runtime/planner.test.py && python3 tests/runtime/loop.test.py && python3 tests/runtime/state.test.py && python3 tests/runtime/tmux.test.py"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mux",
    "multi-agent",
    "hybrid",
    "orchestration",
    "cli"
  ],
  "license": "MIT"
}
